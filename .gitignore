Pods/
.symlinks/

# CocoaPods
!ios/Podfile
ios/Podfile.lock


# =============================================================================
# macOS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
# macOS icon file (has a carriage return in real usage — covered by ._* above)
Icon


