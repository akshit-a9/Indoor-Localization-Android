.idea/caches/build_file_checksums.ser

# Android Studio navigation editor temp files
.navigation/

# NDK / CMake
.externalNativeBuild/
.cxx/
cmake-build-*/

# Lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/


