# =============================================================================
# GIT LFS — CSV files are tracked via LFS, not ignored
# =============================================================================
# *.csv  ← managed by .gitattributes / Git LFS


# =============================================================================
# FLUTTER / DART
# =============================================================================
# Build outputs
build/
.dart_tool/
.packages
.pub-cache/
.pub/

# Flutter generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Flutter plugin symlinks & lock artefacts
.flutter-plugins
.flutter-plugins-dependencies
.flutter-version

# Dart analysis
.dart_tool/
dart_tool/

# Generated localizations
app_localizations.dart

# Flutter coverage
coverage/


# =============================================================================
# ANDROID (Android Studio / Gradle)
# =============================================================================
# Gradle
*.iml
.gradle/
local.properties
android/.gradle/
android/local.properties
android/captures/
android/app/debug/
android/app/release/
android/app/profile/

# Keystores (never commit secrets)
*.jks
*.keystore

# AAR / APK / AAB artefacts
*.apk
*.aab
*.aar

# Android Studio project files
.idea/
*.iml
*.iws
*.ipr
*.hprof
